# npm peer-dependency resolution mode.
#
# Why: openapi-typescript@7.x pins `typescript@^5.x`, but the rest of the
# toolchain has moved to typescript@~6.x.  Functionally the API types
# generator works fine against TS 6, so the constraint is overly tight on
# the openapi-typescript side.  Without this flag, `npm ci` (used by the
# deploy bootstrap) hard-fails on the peer-dep conflict.
#
# `--legacy-peer-deps` reverts npm 7+ to npm 6 behavior: install the tree
# the lockfile records, log peer warnings, don't refuse to proceed.
#
# `npm install` on most contributors' laptops doesn't hit this because
# npm 11 + their lockfile setup resolves it silently.  npm ci is stricter.
legacy-peer-deps=true
